{
  "id": "Resize2canvas",
  "name": "Resize to Canvas",
  "version": "1.0.2",
  "main": "index.html",
  "host": [
    {
      "app": "PS",
      "minVersion": "23.3.0"
    }
  ],
  "manifestVersion": 5,
  "entrypoints": [
    {
      "type": "panel",
      "id": "resizePanel",
      "label": {
        "default": "Resize Layer to Canvas"
      },
      "icons": [
        {
          "width": 23,
          "height": 23,
          "path": "icon.png",
          "scale": [
            1,
            2
          ],
          "theme": [
            "dark",
            "light",
            "darkest",
            "lightest"
          ]
        }
      ],
      "minimumSize": {
        "width": 260,
        "height": 450
      },
      "maximumSize": {
        "width": 800,
        "height": 800
      },
      "preferredDockedSize": {
        "width": 260,
        "height": 450
      },
      "preferredFloatingSize": {
        "width": 260,
        "height": 450
      }
    },
    {
      "type": "command",
      "id": "cmdFitCanvas",
      "label": {
        "default": "Fit to Canvas (No Crop)"
      },
      "shortcut": {
        "mac": "Cmd+Option+Q",
        "win": "Ctrl+Alt+Q"
      }
    },
    {
      "type": "command",
      "id": "cmdFillCanvas",
      "label": {
        "default": "Fill Canvas (Crop)"
      },
      "shortcut": {
        "mac": "Cmd+Option+Y",
        "win": "Ctrl+Alt+Y"
      }
    }
  ],
  "icons": [
    {
      "width": 23,
      "height": 23,
      "path": "icon.png",
      "scale": [
        1,
        2
      ],
      "theme": [
        "dark",
        "light",
        "darkest",
        "lightest"
      ]
    }
  ],
  "requiredPermissions": {
    "localFileSystem": "request"
  }
}