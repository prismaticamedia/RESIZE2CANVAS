{
  "id": "com.example.resizetocanvas",
  "name": "Resize to Canvas",
  "version": "1.0.1",
  "main": "index.html",
  "host": [
    {
      "app": "PS",
      "minVersion": "23.3.0"
    }
  ],
  "manifestVersion": 5,
  "entrypoints": [
    {
      "type": "panel",
      "id": "resizePanel",
      "label": {
        "default": "Resize Layer to Canvas"
      },
      "minimumSize": {
        "width": 260,
        "height": 220
      },
      "maximumSize": {
        "width": 800,
        "height": 800
      },
      "preferredDockedSize": {
        "width": 260,
        "height": 220
      },
      "preferredFloatingSize": {
        "width": 260,
        "height": 220
      }
    },
    {
      "type": "command",
      "id": "cmdFitCanvas",
      "label": {
        "default": "Fit to Canvas (No Crop)"
      },
      "shortcut": {
        "mac": "Cmd+Opt+Q",
        "win": "Ctrl+Alt+Q"
      }
    },
    {
      "type": "command",
      "id": "cmdFillCanvas",
      "label": {
        "default": "Fill Canvas (Crop)"
      },
      "shortcut": {
        "mac": "Cmd+Opt+Y",
        "win": "Ctrl+Alt+Y"
      }
    }
  ],
  "icons": [
    {
      "width": 23,
      "height": 23,
      "path": "icon.png",
      "scale": [
        1,
        2
      ],
      "theme": [
        "dark",
        "lightbulb",
        "darkest",
        "lightest"
      ]
    }
  ],
  "requiredPermissions": {
    "localFileSystem": "request"
  }
}